# Copy this to .env and fill in your values — never commit .env to git

# Anthropic (AI Chat) — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Analytics 4 Measurement Protocol
# GA_MEASUREMENT_ID  → GA4 → Admin → Data Streams → Stream details → Measurement ID (G-XXXXXXXX)
# GA_API_SECRET      → same page → Measurement Protocol → Create
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_api_secret_here
